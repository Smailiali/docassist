# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/docassist
# Neon example:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/docassist?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/docassist

# Port the Express server listens on (default: 3002)
PORT=3002
