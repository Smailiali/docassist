# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/docassist
# Neon example:   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/docassist?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/docassist

# Port the Express server listens on (default: 3002)
PORT=3002

# Google OAuth credentials — create a project at https://console.cloud.google.com/apis/credentials
# Set the authorised redirect URI to: http://localhost:3002/api/auth/google/callback (dev)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# Frontend URL — used for OAuth success/failure redirects
# Dev: http://localhost:5173   Production: https://your-domain.com
CLIENT_URL=http://localhost:5173

# Session secret — any long random string, keep it private
SESSION_SECRET=change_this_to_a_long_random_secret
